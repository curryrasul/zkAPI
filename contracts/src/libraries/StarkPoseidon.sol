pragma solidity ^0.8.28;

/// @title StarkPoseidon
/// @notice Starknet/Cairo-compatible Poseidon hash over the Stark field.
/// @dev Generated from the locally cached Lambdaworks/Starknet parameters.
library StarkPoseidon {
    uint256 internal constant FIELD_PRIME =
        3618502788666131213697322783095070105623107215331596699973092056135872020481;

    bytes internal constant UNOPTIMIZED_ROUND_CONSTANTS =
        hex"";

    function hash2(uint256 x, uint256 y) internal pure returns (uint256) {
        uint256[3] memory state = [x, y, uint256(2)];
        _permute(state);
        return state[0];
    }

    function hash3(uint256 a, uint256 b, uint256 c) internal pure returns (uint256) {
        uint256[3] memory state;
        state[0] = a;
        state[1] = b;
        _permute(state);
        state[0] = addmod(state[0], c, FIELD_PRIME);
        state[1] = addmod(state[1], 1, FIELD_PRIME);
        _permute(state);
        return state[0];
    }

    function hash5(uint256 a, uint256 b, uint256 c, uint256 d, uint256 e) internal pure returns (uint256) {
        uint256[3] memory state;
        state[0] = a;
        state[1] = b;
        _permute(state);
        state[0] = addmod(state[0], c, FIELD_PRIME);
        state[1] = addmod(state[1], d, FIELD_PRIME);
        _permute(state);
        state[0] = addmod(state[0], e, FIELD_PRIME);
        state[1] = addmod(state[1], 1, FIELD_PRIME);
        _permute(state);
        return state[0];
    }

    function _permute(uint256[3] memory state) private pure {
        bytes memory roundConstants = UNOPTIMIZED_ROUND_CONSTANTS;
        uint256 offset = 0;

        for (uint256 i = 0; i < 4;) {
            _fullRound(state, roundConstants, offset);
            offset += 3;
            unchecked {
                ++i;
            }
        }

        for (uint256 i = 0; i < 83;) {
            _partialRound(state, roundConstants, offset);
            offset += 3;
            unchecked {
                ++i;
            }
        }

        for (uint256 i = 0; i < 4;) {
            _fullRound(state, roundConstants, offset);
            offset += 3;
            unchecked {
                ++i;
            }
        }
    }

    function _fullRound(uint256[3] memory state, bytes memory roundConstants, uint256 offset) private pure {
        state[0] = _cube(addmod(state[0], _loadConstant(roundConstants, offset), FIELD_PRIME));
        state[1] = _cube(addmod(state[1], _loadConstant(roundConstants, offset + 1), FIELD_PRIME));
        state[2] = _cube(addmod(state[2], _loadConstant(roundConstants, offset + 2), FIELD_PRIME));
        _mix(state);
    }

    function _partialRound(uint256[3] memory state, bytes memory roundConstants, uint256 offset) private pure {
        state[0] = addmod(state[0], _loadConstant(roundConstants, offset), FIELD_PRIME);
        state[1] = addmod(state[1], _loadConstant(roundConstants, offset + 1), FIELD_PRIME);
        state[2] = _cube(addmod(state[2], _loadConstant(roundConstants, offset + 2), FIELD_PRIME));
        _mix(state);
    }

    function _mix(uint256[3] memory state) private pure {
        uint256 t = addmod(addmod(state[0], state[1], FIELD_PRIME), state[2], FIELD_PRIME);
        uint256 twoX = addmod(state[0], state[0], FIELD_PRIME);
        uint256 twoY = addmod(state[1], state[1], FIELD_PRIME);
        uint256 threeZ = addmod(addmod(state[2], state[2], FIELD_PRIME), state[2], FIELD_PRIME);

        state[0] = addmod(t, twoX, FIELD_PRIME);
        state[1] = addmod(t, FIELD_PRIME - twoY, FIELD_PRIME);
        state[2] = addmod(t, FIELD_PRIME - threeZ, FIELD_PRIME);
    }

    function _cube(uint256 value) private pure returns (uint256) {
        uint256 square = mulmod(value, value, FIELD_PRIME);
        return mulmod(square, value, FIELD_PRIME);
    }

    function _loadConstant(bytes memory roundConstants, uint256 index) private pure returns (uint256 value) {
        uint256 offset = 0x20 + index * 0x20;
        assembly ("memory-safe") {
            value := mload(add(roundConstants, offset))
        }
    }
}
